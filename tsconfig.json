{
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "eslint.config.js",
        "prettier.config.js",
        "vite.config.js"
    ],
    "exclude": ["ui/**", "src/paraglide/**", "node_modules", "dist"],
    "compilerOptions": {
        "target": "ES2022",
        "jsx": "react-jsx",
        "module": "ESNext",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "ui/*": ["./ui/*"],
            "#/*": ["./src/*"],
            "#/paraglide/*": ["./src/paraglide/*"]
        },
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "allowJs": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,

        /* Linting */
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": true
    }
}
